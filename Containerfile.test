FROM python:3.11-alpine
WORKDIR /test

# bash for the #!/bin/bash test scripts; curl to drive the host breakout receiver.
# (python3 is already in the base image; nothing here needs podman or sudo anymore.)
RUN apk add --no-cache bash curl

# Copy the counter app into the test workdir
COPY src/counter.py .

# Copy tests layout
COPY test/ .

RUN chmod +x *.sh counter.py

ENTRYPOINT ["./run_tests.sh"]

STOPSIGNAL SIGKILL
