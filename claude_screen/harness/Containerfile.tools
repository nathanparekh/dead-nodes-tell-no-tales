# Static-analysis toolbox for C + shell.
# Build:  podman build -t dnt-tools -f claude_screen/harness/Containerfile.tools claude_screen/harness
# Used by run.sh (repo mounted at /work).
FROM docker.io/library/debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    clang \
    clang-tools \
    cppcheck \
    shellcheck \
    make \
    libc6-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /work
